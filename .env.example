# Copy to .env and fill values. Never commit .env.
# Bootstrap is ONE-TIME (or when schema changes): `npm run db:bootstrap`.
# Restarting Postgres/Mongo does NOT re-run seeds unless you execute those commands again.

# --- Shared / gateway ---
INTERNAL_SHARED_SECRET=change-me-use-long-random-string
GATEWAY_PORT=3000

# Optional: comma-separated origins; empty = permissive dev
# Include localhost and 127.0.0.1 for each dev port (4200 users, 4201 vendors, 4202 qa-lab, 4203 admin).
# CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://127.0.0.1:4200,http://127.0.0.1:4201,http://127.0.0.1:4202,http://127.0.0.1:4203

# --- PostgreSQL (user-service, order-service, product-service vendor check, admin-service sessions) ---
# Must match the DB Docker uses if you run the full stack (same port as amaz-postgres publish).
# If another Postgres listens on 5432, use db:bootstrap:docker instead of db:bootstrap.
PG_HOST=localhost
PG_PORT=5432
PG_USER=amaz
PG_PASSWORD=your_pg_password
PG_DATABASE=amaz_db
# PG_SSL=false

# --- MongoDB (product-service, messaging, ai) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=amaz

# --- user-service (3001) ---
USER_SERVICE_PORT=3001
ACCESS_HMAC_SECRET=change-me-access-hmac
REFRESH_HMAC_SECRET=change-me-refresh-hmac
PEPPER_SERVICE_URL=http://localhost:3006
# Dev fallback if pepper unreachable:
# PEPPER_CLIENT_SECRET=

# --- product-service (3002) ---
PRODUCT_SERVICE_PORT=3002

# --- order-service (3003) ---
ORDER_SERVICE_PORT=3003

# --- messaging (3004), ai (3005), pepper (3006) ---
MESSAGING_SERVICE_PORT=3004
AI_SERVICE_PORT=3005
PEPPER_SERVICE_PORT=3006

# --- Gateway → microservices (names match gateway/src/config.js) ---
USERS_SERVICE_URL=http://localhost:3001
PRODUCTS_SERVICE_URL=http://localhost:3002
ORDERS_SERVICE_URL=http://localhost:3003
MESSAGING_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005
PEPPER_SERVICE_URL=http://localhost:3006
PEPPER_PRIMARY_URL=http://localhost:3007

# --- admin-service → user-service introspection ---
USER_SERVICE_URL=http://localhost:3001

# --- admin-service (3010) ---
ADMIN_SERVICE_PORT=3010
# USER_SERVICE_URL must match user-service (for /internal/admin/authenticate)
# ADMIN_SESSION_SECRET=change-me-long-secret-for-express-session
# Optional: DATABASE_URL=postgres://user:pass@host:5432/amaz_db

# --- Seeds (dev) ---
# SEED_DEFAULT_PASSWORD=Amaz@2026!
