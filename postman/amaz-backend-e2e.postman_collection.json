            "value": "{{powNonce}}"
          },
          {
            "key": "X-PoW-Proof",
            "value": "{{powProof}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"articles\": [\n    { \"produitId\": \"{{productId}}\", \"quantite\": 1 }\n  ],\n  \"adresseLivraison\": { \"ville\": \"Paris\", \"ligne1\": \"12 Rue Exemple\" },\n  \"methodePaiement\": \"card\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/commandes",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
