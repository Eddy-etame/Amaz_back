          },
          {
            "key": "X-PoW-Timestamp",
            "value": "{{powTimestamp}}"
          },
          {
            "key": "X-PoW-Nonce",
            "value": "{{powNonce}}"
          },
          {
            "key": "X-PoW-Proof",
            "value": "{{powProof}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"vendorId\": \"{{vendorId}}\",\n  \"content\": \"Bonjour, disponibilité produit ?\",\n  \"subject\": \"Question produit\",\n  \"userName\": \"{{userName}}\",\n  \"vendorName\": \"{{vendorName}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/messages",
          "host": [
